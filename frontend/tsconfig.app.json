{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    /* โมดูลกลางสูตรการเงิน (ใช้ร่วมกับ backend) */
    "paths": { "@shared/*": ["../shared/*"] }
  },
  "include": ["src", "../shared"],
  // ไฟล์เทสต์ของ shared import 'vitest' ซึ่งอยู่ใน devDependencies ของ root
  // แต่ Vercel ติดตั้งเฉพาะ frontend/package.json → tsc -b จะพังตอน build
  // เทสต์ยังรันครบผ่าน `npm test` (vitest แปลงไฟล์เอง ไม่ผ่าน tsc)
  "exclude": ["../shared/**/*.test.ts"]
}
